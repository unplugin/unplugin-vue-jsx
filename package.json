{
  "name": "unplugin-vue-jsx",
  "type": "module",
  "version": "0.9.0",
  "packageManager": "pnpm@11.0.9",
  "description": "A Vue JSX plugin.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/unplugin/unplugin-vue-jsx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unplugin/unplugin-vue-jsx.git"
  },
  "bugs": {
    "url": "https://github.com/unplugin/unplugin-vue-jsx/issues"
  },
  "keywords": [
    "unplugin",
    "rollup",
    "vite",
    "esbuild",
    "webpack",
    "rolldown"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./api": "./dist/api.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./farm": "./dist/farm.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./vite": "./dist/vite.mjs",
    "./webpack": "./dist/webpack.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "test": "vitest",
    "typecheck": "tsgo --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@vue/babel-plugin-jsx": "^2.0.1",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@babel/plugin-syntax-typescript": "^7.28.6",
    "@sxzz/eslint-config": "^8.0.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260510.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "rolldown-plugin-require-cjs": "^0.4.0",
    "tsdown": "^0.22.0",
    "tsdown-preset-sxzz": "^0.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vue": "^3.5.34"
  },
  "prettier": "@sxzz/prettier-config"
}
